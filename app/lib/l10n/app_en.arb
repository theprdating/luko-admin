  "onboarding1Title": "You deserve\nsomeone like you.",
  "@onboarding1Title": { "description": "Onboarding page 1 title" },

  "onboarding1Body": "Intentionality shows.\n\nThe care someone puts into how they present themselves\n\nThat's how they'll show up for you too.",
  "@onboarding1Body": { "description": "Onboarding page 1 body" },

  "onboarding2Title": "We screen\nfor intention.",
  "@onboarding2Title": { "description": "Onboarding page 2 title" },

  "onboarding2Body": "Not algorithms. Real people.\n\nEvery account on PR Dating is reviewed by hand — because attitude can't be automated.\n",
  "@onboarding2Body": { "description": "Onboarding page 2 body" },

  "onboarding3Title": "Good connections\naren't luck.",
  "@onboarding3Title": { "description": "Onboarding page 3 title" },

  "onboarding3Body": "No more endless scrolling.\n\nEvery day, PR Dating curates a small circle of people — each one genuinely worth your time.\n\nYou take yourself seriously.\nYou deserve someone who does too.",
  "@onboarding3Body": { "description": "Onboarding page 3 body" },

  "onboarding1Quote1": "These are the photos they handpicked to show you.\n Imagine what meeting them looks like.",
  "@onboarding1Quote1": { "description": "Onboarding page 1 background quote 1" },
  "onboarding1Quote2": "Am I asking for too much?",
  "@onboarding1Quote2": { "description": "Onboarding page 1 background quote 2" },
  "onboarding1Quote3": "I spent an hour getting ready and they showed up like…",
  "@onboarding1Quote3": { "description": "Onboarding page 1 background quote 3" },
  "onboarding1Quote4": "Why does nobody put in effort anymore?",
  "@onboarding1Quote4": { "description": "Onboarding page 1 background quote 4" },
  "onboarding1Quote5": "Their photos look like they couldn't care less",
  "@onboarding1Quote5": { "description": "Onboarding page 1 background quote 5" },
  "onboarding1Quote6": "Am I the only one who actually cares about showing up?",
  "@onboarding1Quote6": { "description": "Onboarding page 1 background quote 6" },

  "onboarding2Quote1": "How do I even know if he's real?",
  "@onboarding2Quote1": { "description": "Onboarding page 2 background quote 1" },
  "onboarding2Quote2": "Fake photos, fake info — all of it",
  "@onboarding2Quote2": { "description": "Onboarding page 2 background quote 2" },
  "onboarding2Quote3": "It feels like I'm talking to a bot",
  "@onboarding2Quote3": { "description": "Onboarding page 2 background quote 3" },
  "onboarding2Quote4": "I can't tell if there's a real person on the other side",
  "@onboarding2Quote4": { "description": "Onboarding page 2 background quote 4" },
  "onboarding2Quote5": "Chatted for weeks before realizing it was a fake account",
  "@onboarding2Quote5": { "description": "Onboarding page 2 background quote 5" },
  "onboarding2Quote6": "We had plans and then they just vanished…",
  "@onboarding2Quote6": { "description": "Onboarding page 2 background quote 6" },

  "onboarding3Quote1": "Scrolled forever and nobody feels right",
  "@onboarding3Quote1": { "description": "Onboarding page 3 background quote 1" },
  "onboarding3Quote2": "I'm so tired of swiping",
  "@onboarding3Quote2": { "description": "Onboarding page 3 background quote 2" },
  "onboarding3Quote3": "After a while I forgot what I was even looking for",
  "@onboarding3Quote3": { "description": "Onboarding page 3 background quote 3" },
  "onboarding3Quote4": "Is this even working?",
  "@onboarding3Quote4": { "description": "Onboarding page 3 background quote 4" },
  "onboarding3Quote5": "99+ messages a day and I can't connect with anyone",
  "@onboarding3Quote5": { "description": "Onboarding page 3 background quote 5" },
  "onboarding3Quote6": "There has to be a better way than this…",
