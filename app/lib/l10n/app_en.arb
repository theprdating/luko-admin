  "onboarding2Title": "We screen\nfor intention.",
  "@onboarding2Title": { "description": "Onboarding page 2 title" },

  "onboarding2Body": "Not algorithms. Real people.\n\nEvery account on PR Dating is reviewed by hand — because attitude can't be automated.\n",
