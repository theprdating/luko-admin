  "onboarding2Quote5": "「聊了好久才發現是假帳號」",
  "@onboarding2Quote5": { "description": "Onboarding 第 2 頁背景引號 5" },
  "onboarding2Quote6": "「說好見面，卻突然消失了⋯」",
  "@onboarding2Quote6": { "description": "Onboarding 第 2 頁背景引號 6" },

  "onboarding3Quote1": "「滑了好久一個都不對」",
