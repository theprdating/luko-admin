  "onboarding1Quote3": "「我打扮了一小時，對方卻⋯」",
  "@onboarding1Quote3": { "description": "Onboarding 第 1 頁背景引號 3" },
  "onboarding1Quote4": "「怎麼都不認真打扮？」",
  "@onboarding1Quote4": { "description": "Onboarding 第 1 頁背景引號 4" },
  "onboarding1Quote5": "「對方的照片看起來好敷衍」",
  "@onboarding1Quote5": { "description": "Onboarding 第 1 頁背景引號 5" },
  "onboarding1Quote6": "「難道只有我在乎見面這件事？」",
  "@onboarding1Quote6": { "description": "Onboarding 第 1 頁背景引號 6" },

  "onboarding2Quote1": "「怎麼知道他是真的？」",
  "@onboarding2Quote1": { "description": "Onboarding 第 2 頁背景引號 1" },
  "onboarding2Quote2": "「都是假照片假資訊」",
  "@onboarding2Quote2": { "description": "Onboarding 第 2 頁背景引號 2" },
  "onboarding2Quote3": "「感覺在跟機器人聊天」",
  "@onboarding2Quote3": { "description": "Onboarding 第 2 頁背景引號 3" },
  "onboarding2Quote4": "「搞不清楚對面是不是真人」",
